# ═══════════════════════════════════════════════
# PSV INFOTECH — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# ── Email (Gmail SMTP) ───────────────────────────
# Enable "App Passwords" in your Google Account settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_TO=contact@psvinfotech.com

# ── OpenAI API ───────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
# Leave blank to use built-in fallback responses
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Admin Panel ──────────────────────────────────
# Change this to a strong random secret
ADMIN_TOKEN=psv-admin-secret-2025

# ── Server ───────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
DB_PATH=database.db
